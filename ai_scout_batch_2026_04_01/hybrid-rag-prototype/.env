# LLM Configuration
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
ANTHROPIC_API_KEY="YOUR_ANTHROPIC_API_KEY"
# Optionally, specify a default LLM provider or endpoint
DEFAULT_LLM_PROVIDER="openai" # e.g., "openai", "anthropic", "local"
# For local LLMs, e.g., through Ollama or a local server
LOCAL_LLM_ENDPOINT="http://localhost:11434/v1"
LOCAL_LLM_MODEL="llama3"

# Vector Store Configuration (e.g., Chroma, Pinecone, Weaviate)
# Example for ChromaDB (local persistence)
VECTOR_STORE_TYPE="chroma"
CHROMA_PERSIST_DIRECTORY="./data/vector_store"
# Example for Pinecone (if used)
# VECTOR_STORE_TYPE="pinecone"
# PINECONE_API_KEY="YOUR_PINECONE_API_KEY"
# PINECONE_ENVIRONMENT="YOUR_PINECONE_ENVIRONMENT"
# PINECONE_INDEX_NAME="YOUR_PINECONE_INDEX_NAME"

# Graph Store Configuration (e.g., Neo4j, ArangoDB)
GRAPH_STORE_TYPE="neo4j"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="YOUR_NEO4J_PASSWORD"
# Example for ArangoDB (if used)
# GRAPH_STORE_TYPE="arangodb"
# ARANGO_HOST="http://localhost:8529"
# ARANGO_USER="root"
# ARANGO_PASSWORD="YOUR_ARANGO_PASSWORD"
# ARANGO_DB_NAME="rag_knowledge_graph"

# Structured Data Indexer Configuration (e.g., SQLite for simplicity)
STRUCTURED_DATA_DB_PATH="./data/structured_data.db"

# Embedder Configuration
# Text Embedder
TEXT_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2" # or "text-embedding-ada-002" if using OpenAI
# Code Embedder (can be the same as text or a specialized one)
CODE_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2" # Example, consider a code-specific model if available
# Knowledge Graph Embedder (for nodes and relationships)
KG_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2" # Example, more advanced might use TransE/RotatE specific embeddings

# Data Ingestion & Storage Paths
DOCUMENT_STORAGE_PATH="./data/documents" # Where raw documents are stored
PROCESSED_DATA_PATH="./data/processed" # Where parsed chunks, ASTs, etc., are stored

# Logging Configuration
LOG_LEVEL="INFO" # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Other configurations
# Maximum number of tokens for LLM context window (adjust based on LLM)
MAX_LLM_CONTEXT_TOKENS=8000
# Retrieval top-k for vector search
VECTOR_RETRIEVER_TOP_K=5
# Retrieval depth for KG queries (e.g., number of hops)
KG_RETRIEVER_MAX_HOPS=2