# Application Environment Settings
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=your_super_secret_key_for_any_auth_or_encryption_or_if_using_session

# --- Core Database Configurations ---

# Relational Database (for metadata, file status, user profiles)
# Example: PostgreSQL, SQLite, MySQL
# For SQLite, DATABASE_URL=sqlite:///./data/pmeg_metadata.db
# For PostgreSQL, DATABASE_URL=postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./data/pmeg_metadata.db

# Vector Database (for storing and retrieving cross-modal embeddings)
# Supported types: FAISS (local), PINECONE, WEAVIATE, QDRANT
VECTOR_DB_TYPE=FAISS
# VECTOR_DB_TYPE=PINECONE
# VECTOR_DB_TYPE=WEAVIATE
# VECTOR_DB_TYPE=QDRANT

# Pinecone Configuration (if VECTOR_DB_TYPE=PINECONE)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=your_pinecone_environment_here # e.g., 'us-west-2'
PINECONE_INDEX_NAME=pmeg-embeddings

# Weaviate Configuration (if VECTOR_DB_TYPE=WEAVIATE)
WEAVIATE_URL=http://localhost:8080 # or your Weaviate Cloud URL
WEAVIATE_API_KEY=your_weaviate_api_key_here # for Weaviate Cloud

# Qdrant Configuration (if VECTOR_DB_TYPE=QDRANT)
QDRANT_URL=http://localhost:6333 # or your Qdrant Cloud URL
QDRANT_API_KEY=your_qdrant_api_key_here # for Qdrant Cloud

# FAISS Configuration (if VECTOR_DB_TYPE=FAISS - typically local)
FAISS_INDEX_PATH=./data/faiss_index.bin # Path to store FAISS index file

# Graph Database (for Semantic Entity Graph)
# Supported types: NEO4J, ARANGODB
GRAPH_DB_TYPE=NEO4J
# GRAPH_DB_TYPE=ARANGODB

# Neo4j Configuration (if GRAPH_DB_TYPE=NEO4J)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j

# ArangoDB Configuration (if GRAPH_DB_TYPE=ARANGODB)
ARANGODB_HOST=localhost
ARANGODB_PORT=8529
ARANGODB_USER=root
ARANGODB_PASSWORD=your_arangodb_password_here
ARANGODB_DB_NAME=pmeg_graph

# --- External API Keys for Perception Agents & Models ---

# OpenAI API (for various LLM/embedding/vision tasks)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_organization_id_here # Optional

# Hugging Face API (for models, inference endpoints)
HF_API_KEY=your_huggingface_api_key_here

# Google Cloud Platform (for Vision AI, Speech-to-Text, Video AI, etc.)
# Option 1: Path to service account key file for authenticated access
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/google-service-account-key.json
# Option 2: General API key (less common for server-side authentication)
# GOOGLE_API_KEY=your_google_api_key_here

# AWS Credentials (for Textract, Rekognition, Transcribe, Comprehend)
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1 # e.g., us-west-2

# Microsoft Azure Cognitive Services (for Vision, Speech, Document Intelligence)
AZURE_COGNITIVE_SERVICE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_COGNITIVE_SERVICE_KEY=your_azure_cognitive_service_key_here

# --- Model Specific Configurations ---

# Default embedding model to use
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2 # Example HuggingFace model
EMBEDDING_MODEL_PROVIDER=HUGGINGFACE # or OPENAI if using 'text-embedding-ada-002' etc.

# OCR Agent specific model/endpoint (if not using a general cloud service)
OCR_MODEL_NAME=tesseract # or 'EasyOCR', 'Azure_Document_Intelligence', etc.
# OCR_MODEL_ENDPOINT=http://localhost:8001/ocr # Example for a locally hosted service

# Image Captioning Agent specific model/endpoint
IMAGE_CAPTIONING_MODEL_NAME=Salesforce/blip-image-captioning-large # Example HuggingFace model
# IMAGE_CAPTIONING_MODEL_ENDPOINT=http://localhost:8002/caption

# Audio Transcription Agent specific model/endpoint
AUDIO_TRANSCRIPTION_MODEL_NAME=openai/whisper-large-v2 # Example HuggingFace model
# AUDIO_TRANSCRIPTION_MODEL_ENDPOINT=http://localhost:8003/transcribe

# Video Analysis Agent specific model/endpoint
VIDEO_ANALYSIS_MODEL_NAME=cvit-lab/videomae-base-patch16-224 # Example HuggingFace model
# VIDEO_ANALYSIS_MODEL_ENDPOINT=http://localhost:8004/video_analysis

# Document Parser Agent specific model/endpoint (e.g., for PDF parsing, layout analysis)
DOCUMENT_PARSER_MODEL_NAME=microsoft/layoutlmv3-base # Example HuggingFace model
# DOCUMENT_PARSER_MODEL_ENDPOINT=http://localhost:8005/parse

# --- File System & Ingestion Settings ---
# Path to monitor for new/modified files
WATCHED_FILESYSTEM_PATH=./data/watched_files
# Interval for scanning (in seconds)
FILE_SCAN_INTERVAL_SECONDS=60
# Max file size to process (in MB)
MAX_FILE_SIZE_MB=100

# --- Personalization Settings ---
# Flag to enable/disable user-specific fine-tuning for embeddings
ENABLE_PERSONALIZED_EMBEDDINGS=False
# Default user ID to use if not specified in a query
DEFAULT_USER_ID=prototype_user_001

# --- Other Configurations ---
# Temporary storage for processed files or intermediate outputs
TEMP_STORAGE_PATH=./data/temp_processing
# Queue System (e.g., Redis, RabbitMQ) for task processing (optional for prototype, but good to plan)
# QUEUE_TYPE=REDIS
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0