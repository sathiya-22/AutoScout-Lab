ENVIRONMENT=development

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_TOKEN=your_huggingface_api_token_here
# Uncomment and configure if using a custom local LLM or another provider
# CUSTOM_LLM_ENDPOINT=http://localhost:8000/v1
# CUSTOM_LLM_API_KEY=your_custom_llm_api_key

# Knowledge Integration Layer
# Example: If a proprietary knowledge base needs an API key
KNOWLEDGE_BASE_API_KEY=your_kb_api_key_here
# Example: SPARQL endpoint for Wikidata (public, usually doesn't need a key)
# WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# Database Configuration (for storing validated data, HIL feedback, etc.)
# Using SQLite for simplicity in a prototype
DATABASE_URL=sqlite:///./gti_generator.db
# For PostgreSQL example:
# DATABASE_URL=postgresql://user:password@host:port/dbname

# API Server Configuration (for Human-in-the-Loop interface)
API_HOST=0.0.0.0
API_PORT=8000

# Application Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Optional: Default paths for input/output data relative to project root
# (These might also be managed in config.py, but can be overridden here)
# INPUT_TOKENS_FILE=src/data/input/new_tokens.csv
# OUTPUT_SUPERVISION_FILE=src/data/output/generated_supervision.json